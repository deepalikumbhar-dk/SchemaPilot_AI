<?xml version="1.0" encoding="utf-8"?>
<!--
  SchemaPilot AI — web.config
  Required for Azure App Service (Windows) to route all requests through Node.
  For Linux App Service this file is ignored — use startup command instead.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="backend/server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- Route all /api/* to Node backend -->
        <rule name="API">
          <match url="^api/.*" />
          <action type="Rewrite" url="backend/server.js" />
        </rule>
        <!-- Route everything else to Node (which serves dist/index.html) -->
        <rule name="SPA">
          <match url=".*" />
          <action type="Rewrite" url="backend/server.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode node_env="production" loggingEnabled="true" logDirectory="iisnode" />
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".env" />
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
