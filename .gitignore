.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── OS Files ──────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ── Logs ──────────────────────────────────────
logs/
*.log
*.log.*
log/

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ── Temporary & Cache ─────────────────────────
tmp/
temp/
.tmp/
.cache/
*.tmp
*.temp
*.bak
*.orig
*.rej

