.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
secrets.toml
secrets.json
*.pem
*.key
*.p8
*.p12
*.pfx

# ── Node ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm
.yarn/

# ── Vite / Build Output ───────────────────────
dist/
dist-ssr/
build/
.vite/
*.local

# ── Editor & IDE ──────────────────────────────
